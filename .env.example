# Copy to .env.local and fill in values.
# See supabase/SETUP.md and docs/production-launch.md.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Default bucket name in app is vendor-images if unset.
SUPABASE_VENDOR_IMAGES_BUCKET=vendor-images
# Storage bucket for ATH Móvil payment receipt uploads.
SUPABASE_ATH_RECEIPTS_BUCKET=ath-receipts
NEXT_PUBLIC_APP_URL=http://localhost:3000

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_VENDOR_PRICE_ID=

ENABLE_VENDOR_MODE=true
ENABLE_STRICT_DB_MODE=true
# Omit or set false for realistic vendor billing locally; defaults to bypass in dev when unset.
# ENABLE_VENDOR_BILLING_BYPASS=false

RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=no-reply@yourdomain.com
